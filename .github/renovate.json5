{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    "github>kachick/renovate-config-dprint#1.3.0",
    "helpers:pinGitHubActionDigestsToSemver",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)",
    ":dependencyDashboard",
    ":timezone(Asia/Tokyo)",
  ],
  prConcurrentLimit: 10,
  prHourlyLimit: 0,
  labels: ["dependencies"],
  rangeStrategy: "replace",
  configMigration: true,
  dependencyDashboard: true,
  dependencyDashboardTitle: "Renovate Dependency Dashboard",
  semanticCommitType: "chore",
  semanticCommitScope: "deps",
  minimumReleaseAge: "3 days",
  internalChecksFilter: "strict",
  automerge: true,
  automergeType: "pr",
  // Refresh mise.lock for in-range updates. The mise manager does NOT support
  // rangeStrategy "update-lockfile" (its updateLockedDependency is a stub that
  // reports "unsupported"), so per-dependency lockfile-only updates are dropped.
  // lockFileMaintenance is the only mechanism that refreshes mise.lock without
  // touching mise.toml: it runs `mise lock` (via the manager's updateArtifacts),
  // re-resolving every constraint to the latest matching version. Requires "mise"
  // in allowedUnsafeExecutions on the runner (set via
  // RENOVATE_ALLOWED_UNSAFE_EXECUTIONS in renovate.yaml).
  lockFileMaintenance: {
    enabled: true,
  },
  // The pre-commit manager is disabled by default; enable it so that the
  // `rev:` of third-party hook repos in .pre-commit-config.yaml is updated.
  "pre-commit": {
    enabled: true,
  },
  packageRules: [
    // ---- GitHub Actions: group multiple updates, but keep single-update PR titles dependency-specific ----
    {
      matchManagers: ["github-actions"],
      groupName: "github-actions",
      commitMessageTopic: "{{depName}}",
      group: {
        commitMessageTopic: "github-actions",
      },
      semanticCommitType: "ci",
      semanticCommitScope: "deps",
      versioning: "semver",
    },
    // ---- mise + pre-commit + dprint plugins: low-risk dev tooling, grouped together (single-update PR titles stay dependency-specific) ----
    // dprint plugin updates come from the github>kachick/renovate-config-dprint
    // preset, which detects them via custom (regex) managers. This repo defines
    // no other custom managers, so "custom.regex" matches dprint plugins only.
    {
      matchManagers: ["mise", "pre-commit", "custom.regex"],
      groupName: "dev tools",
      commitMessageTopic: "{{depName}}",
      group: {
        commitMessageTopic: "dev tools",
      },
    },
    // ---- mise: keep partial version pins (e.g. prek "0.4") out of mise.toml churn ----
    // aqua-backed tools resolve to the github-tags datasource, which inherits
    // Renovate's default `semver` versioning. Under `semver`, partial pins like
    // "0.4" or "1" are *invalid*, so rangeStrategy "replace" rewrites mise.toml to
    // a full version ("0.4" -> "0.4.5"). `npm` versioning treats them as valid
    // ranges instead: in-range updates leave mise.toml untouched (the new version
    // lands in mise.lock via lockFileMaintenance), while out-of-range updates bump
    // the pin and preserve its format ("0.4" -> "0.5"). Tools on the npm/node/go
    // datasources already use range-aware versioning and need no override.
    {
      matchManagers: ["mise"],
      matchDatasources: ["github-tags"],
      versioning: "npm",
    },
  ],
  customManagers: [
  ],
}
