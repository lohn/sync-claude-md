{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "include-component-in-tag": false,
  "separate-pull-requests": false,
  "packages": {
    ".": {
      "release-type": "node",
      "component": "sync-claude-md-pre-commit",
      "package-name": "sync-claude-md-pre-commit",
      "extra-files": [
        "pyproject.toml",
        "pypi/pyproject.toml",
        { "type": "json", "path": "package.json", "jsonpath": "$.dependencies.sync-claude-md" },
        { "type": "json", "path": "npm/sync-claude-md/package.json", "jsonpath": "$.version" },
        {
          "type": "json",
          "path": "npm/sync-claude-md/package.json",
          "jsonpath": "$.optionalDependencies['sync-claude-md-darwin-arm64']"
        },
        {
          "type": "json",
          "path": "npm/sync-claude-md/package.json",
          "jsonpath": "$.optionalDependencies['sync-claude-md-darwin-x64']"
        },
        {
          "type": "json",
          "path": "npm/sync-claude-md/package.json",
          "jsonpath": "$.optionalDependencies['sync-claude-md-linux-arm64']"
        },
        {
          "type": "json",
          "path": "npm/sync-claude-md/package.json",
          "jsonpath": "$.optionalDependencies['sync-claude-md-linux-x64']"
        },
        {
          "type": "json",
          "path": "npm/sync-claude-md/package.json",
          "jsonpath": "$.optionalDependencies['sync-claude-md-windows-arm64']"
        },
        {
          "type": "json",
          "path": "npm/sync-claude-md/package.json",
          "jsonpath": "$.optionalDependencies['sync-claude-md-windows-x64']"
        },
        { "type": "json", "path": "npm/sync-claude-md-darwin-arm64/package.json", "jsonpath": "$.version" },
        { "type": "json", "path": "npm/sync-claude-md-darwin-x64/package.json", "jsonpath": "$.version" },
        { "type": "json", "path": "npm/sync-claude-md-linux-arm64/package.json", "jsonpath": "$.version" },
        { "type": "json", "path": "npm/sync-claude-md-linux-x64/package.json", "jsonpath": "$.version" },
        { "type": "json", "path": "npm/sync-claude-md-windows-arm64/package.json", "jsonpath": "$.version" },
        { "type": "json", "path": "npm/sync-claude-md-windows-x64/package.json", "jsonpath": "$.version" }
      ]
    }
  }
}
